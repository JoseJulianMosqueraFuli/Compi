# Backend configuration example. Copy to .env and adjust values.

# PostgreSQL connection (matches docker-compose.yml default)
DATABASE_URL=postgresql+psycopg://compi:compi@localhost:5432/compi

# Huawei Health Kit OAuth credentials. If any is missing, MockProvider is used (Req 1.4).
HUAWEI_CLIENT_ID=
HUAWEI_CLIENT_SECRET=
HUAWEI_REDIRECT_URI=

# Background sync interval in minutes
SYNC_INTERVAL_MINUTES=60

# CORS allowed origins (comma-separated list of strings)
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
